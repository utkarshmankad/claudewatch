{
  "name": "claudewatch",
  "version": "0.1.0",
  "description": "Anthropic token usage monitor — daemon, CLI, and web dashboard",
  "type": "module",
  "bin": {
    "claudewatch": "./bin/claudewatch.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "build": "tsc -p tsconfig.json",
    "build:web": "vite src/web --outDir ../../dist/web",
    "dev": "tsx watch src/cli/index.ts",
    "daemon": "tsx src/daemon/index.ts",
    "web": "vite src/web",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.tsx\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.51.0",
    "@inquirer/prompts": "^8.4.2",
    "better-sqlite3": "^9.6.0",
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "express": "5.2.1",
    "ink": "^5.1.0",
    "keytar": "^7.9.0",
    "node-cron": "^3.0.3",
    "node-notifier": "^10.0.1",
    "nodemailer": "^6.9.14",
    "open": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-notifier": "^8.0.5",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@yao-pkg/pkg": "^6.14.2",
    "eslint": "^8.57.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vitest": "^4.1.5"
  }
}
